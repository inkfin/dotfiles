#!/usr/bin/env bash
set -euo pipefail

if ! git rev-parse --git-dir >/dev/null 2>&1; then
  echo "Not inside a Git repository." >&2
  exit 1
fi

if [ -z "${AI_COMMIT_CMD:-}" ]; then
  echo "AI_COMMIT_CMD is not set." >&2
  echo 'Example: AI_COMMIT_CMD='"'"'claude-internal -p "$1"'"'"'' >&2
  exit 1
fi

diff_output="$(git diff --cached)"

if [ -z "$diff_output" ]; then
  echo "No staged changes." >&2
  exit 1
fi

staged_files="$(git diff --cached --name-status)"
staged_stat="$(git diff --cached --stat)"
recent_commits="$(git log --oneline -10 2>/dev/null || true)"
commit_template_path="$(git config --get commit.template || true)"
commit_template=""

if [ -n "$commit_template_path" ] && [ -f "$commit_template_path" ]; then
  commit_template="$(cat "$commit_template_path")"
fi

prompt="
You are an expert at writing Git commit messages.

Write exactly one Conventional Commit subject line for the staged changes.

Hard requirements:
1. Output exactly one line and nothing else.
2. The line must be a valid commit subject in this format:
   <type>(<scope>): <subject>
   or
   <type>: <subject>
3. Allowed types: feat, fix, docs, style, refactor, perf, test, chore, build, ci, revert.
4. Use present tense.
5. Do not use quotes, bullets, numbering, markdown, explanations, prefixes, or commentary.
6. Do not mention the user, request, prompt, or reasoning process.
7. If scope is unclear, omit it instead of inventing a bad one.
8. Follow the commit template guidance below.

Reject any response that is not itself the final commit subject line.

Recent commits for context:
$recent_commits

Commit template guidance:
$commit_template

Staged files:
$staged_files

Changes summary:
$staged_stat

\`\`\`diff
$diff_output
\`\`\`
"

msg="$(sh -c "$AI_COMMIT_CMD" _ "$prompt" | grep -E '^(feat|fix|docs|style|refactor|perf|test|chore|build|ci|revert)(\([^)]+\))?!?: .+' | head -n 1 | tr -d '\r')"

if [ -z "$msg" ]; then
  echo "Failed to generate a valid conventional commit message." >&2
  exit 1
fi

printf 'Using commit message: %s\n' "$msg" >&2
exec git commit -m "$msg" "$@"
