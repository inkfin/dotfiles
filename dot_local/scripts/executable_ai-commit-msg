#!/usr/bin/env python3
"""Generate a Conventional Commit message from staged changes via DeepSeek API.

Environment variables:
  DEEPSEEK_API_KEY  (required)  API key from https://platform.deepseek.com
  DEEPSEEK_MODEL    (optional)  default: deepseek-chat
  DEEPSEEK_BASE_URL (optional)  default: https://api.deepseek.com
"""

import json
import os
import re
import subprocess
import sys
import urllib.request


def run(*args: str) -> str:
    return subprocess.check_output(args, text=True, stderr=subprocess.DEVNULL).strip()


def main() -> None:
    try:
        run("git", "rev-parse", "--git-dir")
    except subprocess.CalledProcessError:
        print("Not inside a Git repository.", file=sys.stderr)
        sys.exit(1)

    diff = run("git", "diff", "--cached")
    if not diff:
        print("No staged changes.", file=sys.stderr)
        sys.exit(1)

    files    = run("git", "diff", "--cached", "--name-status")
    stat     = run("git", "diff", "--cached", "--stat")
    commits  = run("git", "log", "--oneline", "-10")
    tmpl     = run("git", "config", "--get", "commit.template")

    commit_template = ""
    if tmpl:
        try:
            with open(tmpl, encoding="utf-8") as f:
                commit_template = f.read()
        except OSError:
            pass

    prompt = f"""You are an expert at writing Git commit messages.

Write exactly one Conventional Commit subject line for the staged changes.

Hard requirements:
1. Output exactly one line and nothing else.
2. The line must be a valid commit subject in this format:
   <type>(<scope>): <subject>
   or
   <type>: <subject>
3. Allowed types: feat, fix, docs, style, refactor, perf, test, chore, build, ci, revert.
4. Use present tense.
5. Do not use quotes, bullets, numbering, markdown, explanations, prefixes, or commentary.
6. Do not mention the user, request, prompt, or reasoning process.
7. If scope is unclear, omit it instead of inventing a bad one.
8. Follow the commit template guidance below.

Recent commits for context:
{commits}

Commit template guidance:
{commit_template}

Staged files:
{files}

Changes summary:
{stat}

```diff
{diff}
```"""

    api_key = os.environ.get("DEEPSEEK_API_KEY", "")
    if not api_key:
        print(
            "DEEPSEEK_API_KEY is not set.\n"
            "  export DEEPSEEK_API_KEY='sk-your-key-here'\n"
            "  export DEEPSEEK_MODEL='deepseek-chat'   # optional"
        )
        sys.exit(1)

    base_url = os.environ.get("DEEPSEEK_BASE_URL", "https://api.deepseek.com")
    model    = os.environ.get("DEEPSEEK_MODEL", "deepseek-chat")

    body = json.dumps({
        "model": model,
        "messages": [
            {"role": "system", "content": (
                "You are an expert at writing Git commit messages. "
                "Output exactly one conventional commit subject line and nothing else."
            )},
            {"role": "user", "content": prompt},
        ],
        "stream": False,
    }).encode()

    req = urllib.request.Request(
        f"{base_url}/chat/completions",
        data=body,
        headers={
            "Content-Type": "application/json",
            "Authorization": f"Bearer {api_key}",
        },
    )

    try:
        with urllib.request.urlopen(req, timeout=60) as resp:
            data = json.loads(resp.read())
        raw = data["choices"][0]["message"]["content"].strip()
    except (urllib.error.URLError, urllib.error.HTTPError) as e:
        print(f"API request failed: {e}", file=sys.stderr)
        sys.exit(1)
    except (KeyError, IndexError, json.JSONDecodeError) as e:
        print(f"Failed to parse API response: {e}", file=sys.stderr)
        sys.exit(1)

    pattern = r'^(feat|fix|docs|style|refactor|perf|test|chore|build|ci|revert)(\([^)]+\))?!?: .+'
    match = re.search(pattern, raw)
    if not match:
        print(f"Failed to generate a valid conventional commit message.\nGot: {raw}", file=sys.stderr)
        sys.exit(1)

    msg = match.group(0)
    print(f"Using commit message: {msg}", file=sys.stderr)
    os.execvp("git", ["git", "commit", "-m", msg] + sys.argv[1:])


if __name__ == "__main__":
    main()
