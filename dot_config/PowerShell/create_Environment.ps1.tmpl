# -*- powershell -*-
# PowerShell machine-specific environment
# Generated once by chezmoi, not automatically updated.
# Sourced early in the profile — add per-machine PATH and env vars here.

## PATH
$machinePaths = @(
    "$HOME\.local\bin",
    "$HOME\.local\neovim\bin"
)
foreach ($p in $machinePaths) {
    if ($env:PATH -notlike "*$p*") {
        $env:PATH = "$p$([IO.Path]::PathSeparator)$env:PATH"
    }
}
