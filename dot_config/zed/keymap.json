// Zed keymap
//
// For information on binding keys, see the Zed
// documentation: https://zed.dev/docs/key-bindings
//
// To see the default key bindings run `zed: open default keymap`
// from the command palette.
[
  {
    "context": "Editor",
    "bindings": {
      "ctrl-s": "workspace::Save",
    },
  },
  {
    "context": "Editor && !menu",
    "bindings": {
      "ctrl-shift-c": "editor::Copy",
      "ctrl-shift-v": "editor::Paste",
      "ctrl-s": "workspace::Save",
    },
  },
  {
    "context": "Editor && (vim_mode == insert || vim_mode == normal || vim_mode == visual)",
    "bindings": {},
  },
  {
    "context": "Editor && (vim_mode == normal || vim_mode == visual)",
    "bindings": {
      // Snake
      "s": "vim::PushSneak",
      "Shift-s": "vim::PushSneakBackward",
      // Tabs
      "H": "vim::GoToPreviousTab",
      "L": "vim::GoToTab",
      "space b d": "pane::CloseActiveItem",
      "space b p": "pane::TogglePinTab",
      "space space": "file_finder::Toggle",
      "space /": "pane::DeploySearch",
      "space a a": "agent::ToggleFocus",
    },
  },
  {
    "context": "Editor && (vim_mode == insert) && (edit_prediction && (showing_completions || in_leading_whitespace))",
    "bindings": {
      "alt-l": "editor::AcceptEditPrediction", // for windows
      "cmd-l": "editor::AcceptEditPrediction", // for mac
    },
  },
  {
    "context": "Editor && (vim_mode == insert)",
    "bindings": {},
  },
  {
    "context": "Editor && (vim_mode == normal)",
    "bindings": {
      // cut
      "g r": "editor::FindAllReferences",
      "space h": "editor::Hover",
      "space r n": "editor::Rename",
      "space r f": "editor::Format",
      "space c a": "editor::ToggleCodeActions",
      "space s s": "project_symbols::Toggle",
      "space e": "vim::ToggleProjectPanelFocus",
      // language specific
      "space c h": "editor::SwitchSourceHeader",
    },
  },
  {
    "context": "Editor && (vim_mode == visual)",
    "bindings": {
      "L": "editor::SelectToEndOfLine",
      "H": "editor::SelectToBeginningOfLine",
      "space r f": "editor::FormatSelections",
    },
  },
]
