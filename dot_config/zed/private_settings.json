// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  "agent_ui_font_size": 14.0,
  "agent_buffer_font_size": 13.0,
  "buffer_font_weight": 400.0,
  "indent_guides": {
    "background_coloring": "disabled",
    "coloring": "fixed"
  },
  "preferred_line_length": 120,
  "soft_wrap": "bounded",
  "cursor_blink": false,
  "scroll_beyond_last_line": "one_page",
  // vim settings: https://zed.dev/docs/vim
  // text objects: https://zed.dev/docs/vim#tree-sitter
  "vim_mode": true,
  "vim": {
    "use_smartcase_find": true,
    "use_system_clipboard": "on_yank",
    "toggle_relative_line_numbers": true
  },
  "command_aliases": {
    "x": "\"_x",
    "P": "\"_dP",
  },
  "wsl_connections": [
    {
      "distro_name": "Ubuntu",
      "user": null,
      "projects": [
        {
          "paths": ["/home/inkfin/Code/cpp"],
        },
      ],
    },
  ],
  "ssh_connections": [
    {
      "host": "ink.devcloud.woa.com",
      "username": "finkzhang",
      "port": 36000,
      "args": [],
      "projects": [
        {
          "paths": ["/data/workspace"],
        },
      ],
    },
  ],
  "git_panel": {
    "tree_view": true,
    "sort_by_path": true,
  },
  "show_whitespaces": "trailing",
  "preview_tabs": {
    "enable_keep_preview_on_code_navigation": true,
    "enable_preview_from_file_finder": true,
  },
  "tabs": {
    "file_icons": true,
    "git_status": false,
  },
  "inlay_hints": {
    "enabled": true,
  },
  "prettier": {
    "allowed": true,
  },
  "auto_signature_help": true,
  "inline_code_actions": true,
  "diagnostics": {
    "inline": {
      "enabled": true,
    },
  },
  "ensure_final_newline_on_save": false,
  "remove_trailing_whitespace_on_save": false,
  "format_on_save": "off",
  "terminal": {
    "font_size": 11.0,
    "font_family": "FiraCode Nerd Font Mono",
  },
  "agent": {
    "favorite_models": [
      {
        "provider": "copilot_chat",
        "model": "gpt-5-mini",
        "enable_thinking": false
      },
    ],
    "default_profile": "ask",
    "default_model": {
      "provider": "copilot_chat",
      "model": "gpt-5-mini",
    },
    "model_parameters": [],
  },
  "restore_on_startup": "last_session",
  "edit_predictions": {
    "provider": "copilot",
    "disabled_globs": ["*.log"],
  },
  "icon_theme": "Material Icon Theme",
  "base_keymap": "VSCode",
  "ui_font_size": 14.0,
  "buffer_font_size": 13.0,
  "theme": {
    "mode": "dark",
    "light": "One Light",
    "dark": "One Dark",
  },
  "languages": {
    "Python": {
      "language_servers": ["basedpyright", "!pyright", "!ty", "ruff"],
    },
  },
  "lsp": {
    // Python
    "basedpyright": {
      "settings": {
        "basedpyright.analysis": {
          "typeCheckingMode": "recommended",
          "diagnosticMode": "workspace",
        },
      },
    },
    "ruff": {
      "initialization_options": {
        "settings": {
          "lineLength": 120,
          "configuration": {
            "lint": {
              "ignore": [],
            },
          },
        },
      },
    },
  },
}
