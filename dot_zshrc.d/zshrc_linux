# zshrc Linux


ZSHCONF_HOME="$HOME/.zshrc.d"

# ==== Includes ====

## helper functions
if [[ -r "$ZSHCONF_HOME/helper.zsh" ]]; then
    source "$ZSHCONF_HOME/helper.zsh"
else
    print -u2 "missing zsh helper: $ZSHCONF_HOME/helper.zsh"
    return 1
fi

## prelude environment
source_if_readable "$ZSHCONF_HOME/env.zsh"

## homebrew initialization
source_if_readable "$ZSHCONF_HOME/homebrew.zsh"

## oh-my-zsh configs
source_if_readable "$ZSHCONF_HOME/omz.zsh"

## user custom configs
source_if_readable "$ZSHCONF_HOME/custom.zsh"

## 3rd party plugins
source_if_readable "$ZSHCONF_HOME/plugins.zsh"

## development configs
source_if_readable "$ZSHCONF_HOME/dev.zsh"

## local configs
source_if_readable "$ZSHCONF_HOME/local.zsh"


# ==== Platform specific configs ====

## === Aliases ====

alias pac="brew"
